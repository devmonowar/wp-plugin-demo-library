			"btn_text": "See the tech",
			"btn_url": "#"
		},
		{
			"image_url": "https://devmonowar.github.io/wp-plugin-demo-library/general-slider/assets/images/neon-tech-livestats.jpg",
			"alt": "Glowing live statistics panel with charts and a pulse line",
			"sub_heading": "LIVE STATS",
			"heading": "Watch the numbers climb",
