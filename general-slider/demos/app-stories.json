		"transition": "slide",
		"autoplay": true,
		"speed": 5000,
		"loop": true,
		"arrows": true,
		"dots": true,
		"overlay": 30,
		"overlay_style": "solid",
		"height": 560,
		"focus": "center",
		"fit": "cover",
		"per_page": 1,
		"gap": 16,
		"accent": "#6366f1",
		"ken_burns": false,
		"animate": true,
		"thumbnails": false
	},
	"custom_css": ""
