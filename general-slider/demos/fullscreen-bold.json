{
	"schema_version": 1,
	"plugin": "general-slider",
	"id": "fullscreen-bold",
	"name": "Fullscreen Bold",
	"version": "1.1",
	"title": "Fullscreen Bold",
	"slides": [
		{
			"image_url": "https://devmonowar.github.io/wp-plugin-demo-library/general-slider/assets/images/dramatic-mountain-landscape-black-sand.jpg",
			"alt": "Dramatic black sand beach and misty mountain landscape",
			"sub_heading": "PORTFOLIO",
			"heading": "Bold by design",
			"text": "Work that speaks for itself.",
			"btn_text": "Enter",
			"btn_url": "#"
		},
		{
			"image_url": "https://devmonowar.github.io/wp-plugin-demo-library/general-slider/assets/images/bold-cinematic-mountain-landscape.jpg",
			"alt": "Bold cinematic mountain landscape under a cloudy sky",
			"sub_heading": "STUDIO",
			"heading": "Less, but better",
			"text": "Minimalism with maximum impact.",
			"btn_text": "Explore",
			"btn_url": "#"
		},
		{
			"image_url": "https://devmonowar.github.io/wp-plugin-demo-library/general-slider/assets/images/moody-dramatic-sky-hills-landscape.jpg",
			"alt": "Moody green hills beneath a dramatic stormy sky",
			"sub_heading": "CONTACT",
			"heading": "Let's create",
			"text": "Available for select projects.",
			"btn_text": "Say hello",
			"btn_url": "#"
		}
	],
	"settings": {
		"preset": "fullscreen",
		"skin": "corner",
		"transition": "fade",
		"autoplay": true,
		"speed": 5500,
		"loop": true,
		"arrows": true,
		"dots": true,
		"overlay": 45,
		"overlay_style": "gradient",
		"height": 700,
		"focus": "center",
		"fit": "cover",
		"per_page": 1,
		"gap": 16,
		"accent": "#facc15",
		"ken_burns": true,
		"animate": true,
		"thumbnails": false
	},
	"custom_css": ".gs-slider .gs-slide__title,.gs-slider .gs-slide__sub,.gs-slider .gs-slide__text{text-shadow:0 2px 14px rgba(0,0,0,.55)}"
}
