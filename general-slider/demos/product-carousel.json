		"accent": "#e11d48",
		"ken_burns": false,
		"animate": true,
		"thumbnails": false
	},
	"custom_css": ".gs-slider .gs-slide__overlay{background:linear-gradient(to top,rgba(0,0,0,.62),rgba(0,0,0,0) 58%) !important}.gs-slider .gs-slide{justify-content:flex-end !important}.gs-slider .gs-slide__content{padding:0 16px 26px !important;text-align:center}.gs-slider .gs-slide__title{font-size:26px !important;margin-bottom:10px}"
