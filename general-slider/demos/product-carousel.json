	"settings": {
		"preset": "hero",
		"transition": "slide",
		"autoplay": true,
		"speed": 4000,
		"loop": true,
		"arrows": true,
		"dots": true,
		"overlay": 30,
		"overlay_style": "solid",
		"height": 460,
		"focus": "center",
		"fit": "cover",
		"per_page": 3,
